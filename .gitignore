# ---------------------------------------------------------------------------
# Secrets / 環境変数（最優先）
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.pfx
*.crt
*.p12
secrets/
.secrets/

# Azure / クラウド資格情報
azure.err
*.publishsettings
*.PublishSettings

# ---------------------------------------------------------------------------
# Azure Developer CLI (azd)
# ---------------------------------------------------------------------------
# azd 環境フォルダ（.env / 状態ファイルを含む）
.azure/
# azd によるパッケージ生成物
.azd/
# azd hooks のログ
azd-hooks/*.log

# ---------------------------------------------------------------------------
# Bicep / IaC ビルド成果物
# ---------------------------------------------------------------------------
# bicep build で生成される ARM JSON（infra 配下のソース .bicep からの出力）
infra/**/*.json
# ただし、コミット対象の設定ファイルは残す
!infra/abbreviations.json
!infra/**/*.bicepparam.json

# what-if / デプロイ結果のダンプ
*.whatif.json
deployment-output.json

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 仮想環境
.venv/
venv/
ENV/
env/
.python-version

# uv キャッシュ
.uv-cache/

# テスト / カバレッジ
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# Jupyter
.ipynb_checkpoints/
*.ipynb_meta

# ---------------------------------------------------------------------------
# Node.js（ツールやデモで使う場合）
# ---------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------------------------------------------------------------------------
# IDE / OS
# ---------------------------------------------------------------------------
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json
.idea/
*.swp
*.swo

.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# ログ・一時ファイル
# ---------------------------------------------------------------------------
*.log
logs/
tmp/
temp/
